<file path="lua/config/keymaps.lua">
-- Keymaps are automatically loaded on the VeryLazy event
-- Default keymaps: https://github.com/LazyVim/LazyVim/blob/main/lua/lazyvim/config/autocmds.lua

-- Explorador de archivos (Oil.nvim)
vim.keymap.set("n", "-", "<cmd>Oil<cr>", { desc = "Open parent directory" })

-- Guardado rápido
vim.keymap.set("n", "<leader>w", "<cmd>w<cr>", { desc = "Save file" })

-- NOTA: Se han eliminado 'gd' y 'gD' manuales porque LazyVim ya los trae configurados
-- con mejores integraciones (FzfLua/Telescope).

--------------------------------------------------------------------------------
-- COMPILACIÓN Y EJECUCIÓN JAVA / JSP / MAVEN
--------------------------------------------------------------------------------

-- Compilación universal con Maven (Recomendado para tus proyectos Spring)
vim.keymap.set("n", "<leader>jc", "<cmd>!mvn clean compile<cr>", { desc = "Maven: Clean & Compile" })

-- Ejecutar proyecto con Maven (Carga automática de dependencias)
vim.keymap.set("n", "<leader>rj", "<cmd>!mvn clean compile exec:java<cr>", { desc = "Maven: Run Project" })

-- Atajos para despliegue en Tomcat vía Maven
vim.keymap.set("n", "<leader>md", "<cmd>!mvn tomcat7:deploy<cr>", { desc = "Tomcat: Deploy" })
vim.keymap.set("n", "<leader>mr", "<cmd>!mvn tomcat7:redeploy<cr>", { desc = "Tomcat: Redeploy" })
vim.keymap.set("n", "<leader>mu", "<cmd>!mvn tomcat7:undeploy<cr>", { desc = "Tomcat: Undeploy" })

-- Abrir el archivo JSP o HTML actual en el navegador de forma dinámica
-- Esta función intenta detectar el nombre del proyecto y la carpeta para construir la URL de Tomcat automáticamente.
vim.keymap.set("n", "<leader>r", function()
  local project_name = vim.fn.fnamemodify(vim.fn.getcwd(), ":t")
  local file_name = vim.fn.expand("%:t")
  local parent_dir = vim.fn.fnamemodify(vim.fn.expand("%:p:h"), ":t")
  -- URL construida dinámicamente: http://localhost:8080/NombreProyecto/Carpeta/Archivo.jsp
  local url = string.format("http://localhost:8080/%s/%s/%s", project_name, parent_dir, file_name)
  
  vim.notify("Abriendo: " .. url)
  vim.fn.jobstart({ "xdg-open", url }) -- Usa jobstart para no bloquear el editor
end, { desc = "Tomcat: Open JSP/HTML in Browser" })

--------------------------------------------------------------------------------
-- TERMINAL
--------------------------------------------------------------------------------

-- Permitir salir de terminal-mode con ESC
vim.keymap.set("t", "<Esc>", [[<C-\><C-n>]], { noremap = true, silent = true, desc = "Exit terminal mode" })
</file>


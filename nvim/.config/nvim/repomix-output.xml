            return folder .. "/" .. file
          end,
        },
      },
    },
    inactive_winbar = {
      lualine_c = {
        {
          function()
            local folder = vim.fn.fnamemodify(vim.fn.expand("%:p:h"), ":t")
            local file = vim.fn.expand("%:t")
            return folder .. "/" .. file
          end,
          color = { fg = "#808080" },
        },
      },
    },
  },
}

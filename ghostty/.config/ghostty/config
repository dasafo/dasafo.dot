# Configuración de Ghostty para dasafo.dot
# Renderizado veloz, Wayland/X11 nativo, divisiones y ligaduras

font-family = "UbuntuMono Nerd Font Mono"
font-size = 16

# Paleta de colores (Kanagawa o Solarized)
theme = "Solarized Osaka Night"

# Transparencia
background-opacity = 0.95

# Ocultar la barra superior (decoraciones de ventana)
window-decoration = false 

# Cursor
cursor-style = block
cursor-style-blink = false

# Deshabilitar confirmaciones al cerrar ventanas con procesos
confirm-close-surface = false

# Padding interno
window-padding-x = 0
window-padding-y = 0
window-padding-color = extend
window-padding-balance = true
